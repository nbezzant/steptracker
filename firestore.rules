rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read any profile, but only write their own
    match /users/{uid} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid;
    }

    // Steps: anyone logged in can read; only the owner can write their own steps
    match /steps/{stepId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && resource == null
          ? request.resource.data.uid == request.auth.uid
          : resource.data.uid == request.auth.uid;
    }

    // Teams: anyone can read; no direct client writes (handled via batched user writes)
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
